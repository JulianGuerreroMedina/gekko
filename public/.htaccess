Options -Indexes
Options -Multiviews
ServerSignature Off
ErrorDocument 400 /error404.php
ErrorDocument 401 /error404.php
ErrorDocument 402 /error404.php
ErrorDocument 403 /error404.php
ErrorDocument 404 /error404.php

RewriteEngine On

RewriteRule ^core\.js/(.*)$ assets/core.js/$1 [QSA,L]
RewriteRule ^core\.icons/(.*)$ assets/core.icons/$1 [QSA,L]
RewriteRule ^(js|css|img|chart)/(.*)$ assets/$1/$2 [QSA,L]

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-l
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]

RewriteBase /
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ http://%1/$1 [R=301,L]
